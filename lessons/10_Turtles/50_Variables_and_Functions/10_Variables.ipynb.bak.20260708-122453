    "favorite_color = \"blue\"\n",
    "\n",
    "# Boolean values (True/False)\n",
    "is_sunny = True\n",
    "is_raining = False\n",
    "\n",
    "print(\"Name:\", my_name)\n",
    "print(\"Age:\", my_age)\n",
    "print(\"Temperature:\", temperature)\n",
    "print(\"Favorite color:\", favorite_color)\n",
    "print(\"Is it sunny?\", is_sunny)\n",
